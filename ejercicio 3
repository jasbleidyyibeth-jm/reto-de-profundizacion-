// PROCESO PARA SABER SABER SI SE TIENE QUE ABRIR LA VALVULA DE ESCAPE DE UNA CALDERA
PROCESO PROCEDIMIENTOPARASABERSISETIENEQUEABRIRLAVALVULADEESCAPE
 ESCRIBIR "BIENVENIDO, TE AYUDAREMOS A SABER SI TIENES QUE ABRIR LA VALCULA DE ESCAPE"
 ESCRIBIR "INGRESE LA TEMPERATURA QUE TIENE LA CALDERA"
 LEER TEMPERATURA
 SI TEMPERATURA >=100 ENTONCES 
  ESCRIBIR "ALERTA, ABRIR VALVULA DE ESCAPE"
 FINSI
FINPROCESO
